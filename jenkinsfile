
pipeline {
    agent any

    tools {
        maven 'maven3'
        jdk 'java21'
    }

    stages {

        stage('Hello') {
            steps {
                echo 'Welcome to sonarQube Testing'
            }
        }

        stage('GitCheckout') {
            steps {
                git 'https://github.com/leninbabuk/JavamavenSonarQube.git'
            }
        }

        stage('Maven Clean') {
            steps {
                sh 'mvn clean'
            }
        }

        stage('Maven Compile') {
            steps {
                sh 'mvn compile'
            }
        }

        stage('Maven Build') {
            steps {
                sh 'mvn package'
            }
        }

        stage('Maven Test') {
            steps {
                sh 'mvn test'
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('sonarserver') {
                    sh '''
                        mvn sonar:sonar \
                        -Dsonar.projectKey=my-project \
                        -Dsonar.projectName="My Project"
                    '''
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }
    }
}
